{
  "name": "yflin_web_astro",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "motion:assets": "node scripts/generate_motion_assets.mjs",
    "content:sync": "node scripts/import_publications.mjs",
    "content:report": "node scripts/content_report.mjs",
    "copy:review": "node scripts/copy_tone_report.mjs",
    "visibility:report": "node scripts/visibility_report.mjs",
    "visibility:report:dry-run": "node scripts/visibility_report.mjs --dry-run",
    "visibility:pulse": "node scripts/daily_pulse.mjs",
    "visibility:pulse:gate": "node scripts/daily_pulse_gate.mjs",
    "tracking:gate": "node scripts/tracking_gate.mjs",
    "research-visibility-os:gate": "node scripts/research_visibility_os_gate.mjs",
    "answerability:gate": "node scripts/answerability_gate.mjs",
    "lint:prose": "node scripts/lint_prose.mjs",
    "evidence:gate": "node scripts/evidence_gate.mjs",
    "publication:gate": "node scripts/publication_gate.mjs",
    "video:gate": "node scripts/video_companion_gate.mjs",
    "video:verify:2025-10-6": "node scripts/verify_rethinking_aquifer_video.mjs",
    "predev": "node scripts/generate_motion_assets.mjs && node scripts/import_publications.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/generate_motion_assets.mjs && node scripts/import_publications.mjs && node scripts/publication_gate.mjs && node scripts/video_companion_gate.mjs && node scripts/verify_rethinking_aquifer_video.mjs && node scripts/evidence_gate.mjs && node scripts/lint_prose.mjs",
    "build": "astro build && pagefind --site dist",
    "indexnow": "node scripts/submit_indexnow.mjs",
    "indexnow:dry-run": "node scripts/submit_indexnow.mjs --dry-run",
    "distribution:pack": "node scripts/generate_distribution_pack.mjs",
    "distribution:pack:all": "node scripts/generate_distribution_pack.mjs --all",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.74.0",
    "@rive-app/canvas": "^2.38.1",
    "@tabler/icons": "^3.44.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "gsap": "^3.15.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "fflate": "^0.8.3",
    "pagefind": "^1.4.0",
    "write-good": "^1.0.8"
  }
}
