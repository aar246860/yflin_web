# Copy this file to `.env.production` before running `npm run build`.
# `.env.production` is intentionally git-ignored because these values are account-specific.

# Google Analytics 4 measurement ID. Example: G-XXXXXXXXXX
PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID. Optional, but useful for heatmaps and session recordings.
PUBLIC_CLARITY_PROJECT_ID=

# Cloudflare Web Analytics token. Optional alternative if you use Cloudflare analytics.
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Optional webmaster verification tokens.
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
