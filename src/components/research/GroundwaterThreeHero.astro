<section id="field-view" class="three-wellfield" aria-labelledby="three-wellfield-title" data-three-wellfield>
  <canvas class="three-wellfield__canvas" aria-label="Interactive three-dimensional groundwater wellfield schematic"></canvas>
  <div class="three-wellfield__shade" aria-hidden="true"></div>
  <div class="shell three-wellfield__content">
    <span class="eyebrow">3D field view</span>
    <h2 id="three-wellfield-title">A groundwater decision depends on the field system, not only the fitted curve.</h2>
    <p>
      This interactive scene links aquifer layers, monitoring wells, pumping wells,
      groundwater flow, and a shallow-geothermal thermal plume. It is a conceptual
      field-scale map for explaining why model assumptions must be audited before
      drawdown, recovery, or thermal-response data become design numbers.
    </p>
    <div class="three-wellfield__legend" aria-label="3D scene legend">
      <span><i class="three-wellfield__swatch three-wellfield__swatch--flow"></i>groundwater flow</span>
      <span><i class="three-wellfield__swatch three-wellfield__swatch--heat"></i>thermal plume</span>
      <span><i class="three-wellfield__swatch three-wellfield__swatch--well"></i>well network</span>
    </div>
  </div>
</section>

<script>
  const initializedWellfields = new WeakSet();
  const wellfieldDisposers = new WeakMap();
  let wellfieldModulePromise;

  function loadWellfieldModules() {
    wellfieldModulePromise ??= Promise.all([
      import("three"),
      import("three/examples/jsm/controls/OrbitControls.js"),
    ]);
    return wellfieldModulePromise;
  }

  async function startWellfieldScene(root) {
      if (initializedWellfields.has(root)) return;
      initializedWellfields.add(root);

      const canvas = root.querySelector("canvas");
      if (!(canvas instanceof HTMLCanvasElement)) return;

      const [THREE, { OrbitControls }] = await loadWellfieldModules();
      const rootStyles = getComputedStyle(document.documentElement);
      const cssColor = (name, fallback) => {
        const value = rootStyles.getPropertyValue(name).trim();
        const match = value.match(/^#([0-9a-f]{6})$/i);
        return match ? Number.parseInt(match[1], 16) : fallback;
      };
      const colorTokens = {
        pageDepth: cssColor("--page-depth", 0xf6f2e8),
        surface: cssColor("--surface-warning", 0xf3ead9),
        aquifer: cssColor("--palette-earth", 0xdac9ad),
        aquitard: cssColor("--palette-storage", 0x9fb3aa),
        casing: cssColor("--palette-model", 0x163c3a),
        wellScreen: cssColor("--palette-water-mid", 0x00776d),
        wellScreenEmissive: cssColor("--palette-water-deep", 0x003430),
        thermal: cssColor("--palette-warm", 0xaa3727),
        thermalEmissive: cssColor("--palette-warm", 0x5c120c),
        flow: cssColor("--palette-numerical", 0x00776d),
        particle: cssColor("--palette-water-bright", 0x00a497),
        sky: cssColor("--surface", 0xfff7e8),
        groundLight: cssColor("--palette-uncertain", 0x6d7c79),
      };

      let renderer;
      try {
        renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      } catch {
        root.setAttribute("data-render-fallback", "true");
        return;
      }

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const scene = new THREE.Scene();
      scene.fog = new THREE.Fog(colorTokens.pageDepth, 16, 46);

      const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 120);
      camera.position.set(9, 7, 13);

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.enablePan = false;
      controls.maxDistance = 24;
      controls.minDistance = 8;
      controls.maxPolarAngle = Math.PI * 0.48;
      controls.target.set(0, -0.2, 0);
      controls.autoRotate = !prefersReducedMotion;
      controls.autoRotateSpeed = 0.35;

      scene.add(new THREE.HemisphereLight(colorTokens.sky, colorTokens.groundLight, 2.4));
      const keyLight = new THREE.DirectionalLight(0xffffff, 2.2);
      keyLight.position.set(8, 12, 6);
      scene.add(keyLight);

      const aquiferMaterial = new THREE.MeshStandardMaterial({
        color: colorTokens.aquifer,
        roughness: 0.92,
        metalness: 0.02,
        transparent: true,
        opacity: 0.62,
      });
      const clayMaterial = new THREE.MeshStandardMaterial({
        color: colorTokens.aquitard,
        roughness: 0.95,
        transparent: true,
        opacity: 0.34,
      });
      const layerGeometry = new THREE.BoxGeometry(12, 0.2, 7.4);
      [-1.9, -0.95, -0.05].forEach((y, index) => {
        const layer = new THREE.Mesh(layerGeometry, index === 1 ? clayMaterial : aquiferMaterial);
        layer.position.set(0, y, 0);
        scene.add(layer);
      });

      const surface = new THREE.Mesh(
        new THREE.PlaneGeometry(13, 8, 44, 28),
        new THREE.MeshStandardMaterial({
          color: colorTokens.surface,
          roughness: 0.88,
          transparent: true,
          opacity: 0.92,
        }),
      );
      surface.rotation.x = -Math.PI / 2;
      surface.position.y = 0.36;
      scene.add(surface);

      const wellMaterial = new THREE.MeshStandardMaterial({ color: colorTokens.casing, roughness: 0.42 });
      const screenMaterial = new THREE.MeshStandardMaterial({
        color: colorTokens.wellScreen,
        emissive: colorTokens.wellScreenEmissive,
        emissiveIntensity: 0.25,
        roughness: 0.35,
      });
      const heatMaterial = new THREE.MeshStandardMaterial({
        color: colorTokens.thermal,
        emissive: colorTokens.thermalEmissive,
        emissiveIntensity: 0.25,
        transparent: true,
        opacity: 0.34,
        roughness: 0.55,
      });

      const wellPositions = [
        [-4.2, 0, -1.8, 1.55],
        [-1.2, 0, 1.6, 1.25],
        [2.0, 0, -0.9, 1.75],
        [4.1, 0, 1.8, 1.35],
      ];

      wellPositions.forEach(([x, , z, depth], index) => {
        const casing = new THREE.Mesh(new THREE.CylinderGeometry(0.065, 0.065, depth + 0.8, 18), wellMaterial);
        casing.position.set(x, 0.34 - depth / 2, z);
        scene.add(casing);

        const screen = new THREE.Mesh(new THREE.CylinderGeometry(0.11, 0.11, 0.34, 18), screenMaterial);
        screen.position.set(x, -depth, z);
        scene.add(screen);

        const head = new THREE.Mesh(new THREE.SphereGeometry(index === 2 ? 0.18 : 0.13, 24, 16), index === 2 ? heatMaterial : screenMaterial);
        head.position.set(x, 0.58, z);
        scene.add(head);
      });

      const plume = new THREE.Mesh(
        new THREE.SphereGeometry(1.25, 36, 24),
        heatMaterial,
      );
      plume.scale.set(1.55, 0.34, 0.72);
      plume.position.set(2.55, -0.64, -0.88);
      scene.add(plume);

      const lineMaterial = new THREE.MeshBasicMaterial({ color: colorTokens.flow, transparent: true, opacity: 0.62 });
      const curves = [
        new THREE.CatmullRomCurve3([
          new THREE.Vector3(-5.2, -0.6, -2.4),
          new THREE.Vector3(-2.2, -0.9, -1.2),
          new THREE.Vector3(0.8, -0.75, -0.4),
          new THREE.Vector3(4.8, -0.95, 0.8),
        ]),
        new THREE.CatmullRomCurve3([
          new THREE.Vector3(-4.8, -1.45, 1.8),
          new THREE.Vector3(-1.4, -1.65, 0.9),
          new THREE.Vector3(1.7, -1.45, 0.2),
          new THREE.Vector3(5.0, -1.55, -1.2),
        ]),
      ];

      curves.forEach((curve) => {
        const tube = new THREE.Mesh(new THREE.TubeGeometry(curve, 80, 0.018, 8, false), lineMaterial);
        scene.add(tube);
      });

      const particleMaterial = new THREE.MeshBasicMaterial({ color: colorTokens.particle });
      const particles = [];
      curves.forEach((curve, curveIndex) => {
        for (let i = 0; i < 9; i += 1) {
          const particle = new THREE.Mesh(new THREE.SphereGeometry(0.045, 12, 8), particleMaterial);
          scene.add(particle);
          particles.push({ mesh: particle, curve, phase: i / 9 + curveIndex * 0.18 });
        }
      });

      function resize() {
        const rect = root.getBoundingClientRect();
        const width = Math.max(320, Math.floor(rect.width));
        const height = Math.max(360, Math.floor(canvas.clientHeight || rect.height));
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(width, height, false);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
      }

      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(root);
      resize();

      let animationFrame = 0;
      function disposeScene() {
        if (animationFrame) window.cancelAnimationFrame(animationFrame);
        resizeObserver.disconnect();
        controls.dispose();
        scene.traverse((object) => {
          if (object.geometry) object.geometry.dispose();
          if (object.material) {
            const materials = Array.isArray(object.material) ? object.material : [object.material];
            materials.forEach((material) => material.dispose());
          }
        });
        renderer.dispose();
        initializedWellfields.delete(root);
        wellfieldDisposers.delete(root);
      }

      wellfieldDisposers.set(root, disposeScene);

      function render(time = 0) {
        const seconds = time * 0.001;
        if (!prefersReducedMotion) {
          plume.rotation.y = seconds * 0.22;
          particles.forEach((particle) => {
            const point = particle.curve.getPoint((particle.phase + seconds * 0.045) % 1);
            particle.mesh.position.copy(point);
          });
          controls.update();
          renderer.render(scene, camera);
          animationFrame = requestAnimationFrame(render);
          return;
        }

        controls.update();
        renderer.render(scene, camera);
      }

      render();
  }

  function initWellfieldScenes() {
    document.querySelectorAll("[data-three-wellfield]").forEach((root) => {
      if (initializedWellfields.has(root)) return;

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (!entries.some((entry) => entry.isIntersecting)) return;
            observer.disconnect();
            void startWellfieldScene(root);
          },
          { rootMargin: "420px 0px" },
        );
        observer.observe(root);
        wellfieldDisposers.set(root, () => {
          observer.disconnect();
          initializedWellfields.delete(root);
          wellfieldDisposers.delete(root);
        });
        return;
      }

      void startWellfieldScene(root);
    });
  }

  initWellfieldScenes();
  document.addEventListener("astro:page-load", initWellfieldScenes);
  document.addEventListener("astro:before-swap", () => {
    document.querySelectorAll("[data-three-wellfield]").forEach((root) => {
      wellfieldDisposers.get(root)?.();
    });
  });
</script>
