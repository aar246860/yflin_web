---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
---

<section class="rereview-feature" aria-labelledby="rereview-feature-title">
  <div class="rereview-feature__shell">
    <div class="rereview-feature__copy">
      <p class="rereview-feature__kicker">My Papers, Re-reviewed · Episode 01</p>
      <h2 id="rereview-feature-title">A general solution to a very specific aquifer.</h2>
      <p>
        I returned to my first Journal of Hydrology paper with ten years of hindsight. The mathematics still stands.
        The field geometry, inversion pathway, and sensitivity analysis deserve a less polite second review.
      </p>
      <a href={withBase("/papers-re-reviewed/")}>
        Read the retrospective <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="rereview-feature__player">
      <video
        controls
        playsinline
        preload="metadata"
        poster={withBase("/videos/re-reviewed/2016-general-model/reviewer-3-2016.webp")}
        width="1080"
        height="1920"
        aria-label="Reviewer number three revisits the 2016 general analytical aquifer model"
      >
        <source
          src={withBase("/videos/re-reviewed/2016-general-model/reviewer-3-2016.mp4")}
          type="video/mp4"
        />
        <track
          kind="captions"
          src={withBase("/videos/re-reviewed/2016-general-model/reviewer-3-2016.en.vtt")}
          srclang="en"
          label="English"
          default
        />
        Your browser does not support the video element.
      </video>
    </div>
  </div>
</section>

<style>
  .rereview-feature {
    --rereview-feature-kicker-spacing: 0.1em;
    --rereview-feature-kicker-margin: 1.15rem;
    --rereview-feature-title-leading: 1.02;
    --rereview-feature-title-measure: 13ch;
    --rereview-feature-copy-margin: 1.45rem 0 1.7rem;
    --rereview-feature-copy-measure: 61ch;
    --rereview-feature-link-size: 0.88rem;
    --rereview-feature-link-gap: 0.55rem;
    --rereview-feature-link-padding: 0.32rem;
    --rereview-feature-focus-width: 3px;
    --rereview-feature-focus-offset: 4px;
    --rereview-feature-shadow: 1.25rem 1.4rem 0 rgb(var(--shadow-rgb) / 0.12);
    --rereview-feature-player-width: 340px;
    --rereview-feature-player-mobile-width: min(86vw, 360px);
    --rereview-feature-shell-columns: minmax(0, 1fr) minmax(260px, 0.54fr);
    --rereview-feature-shell-measure: 1120px;
    --rereview-feature-copy-shell-measure: 650px;
    background: var(--group-wax);
    border-block: 1px solid rgb(var(--text-rgb) / 0.14);
    color: var(--text);
  }

  .rereview-feature__shell {
    align-items: center;
    display: grid;
    gap: var(--space-layout-gap);
    grid-template-columns: var(--rereview-feature-shell-columns);
    margin: 0 auto;
    max-width: var(--rereview-feature-shell-measure);
    padding: var(--space-section-large) var(--space-content-inline);
  }

  .rereview-feature__copy {
    max-width: var(--rereview-feature-copy-shell-measure);
  }

  .rereview-feature__kicker {
    color: var(--palette-numerical);
    font-size: var(--type-label);
    font-weight: 800;
    letter-spacing: var(--rereview-feature-kicker-spacing);
    margin: 0 0 var(--rereview-feature-kicker-margin);
    text-transform: uppercase;
  }

  .rereview-feature h2 {
    font-family: var(--font-serif);
    font-size: var(--type-display-feature);
    letter-spacing: 0;
    line-height: var(--rereview-feature-title-leading);
    margin: 0;
    max-width: var(--rereview-feature-title-measure);
  }

  .rereview-feature__copy > p:not(.rereview-feature__kicker) {
    color: rgb(var(--text-rgb) / 0.72);
    font-size: var(--type-body-large);
    line-height: var(--leading-body);
    margin: var(--rereview-feature-copy-margin);
    max-width: var(--rereview-feature-copy-measure);
  }

  .rereview-feature a {
    border-bottom: 2px solid var(--palette-warm);
    color: var(--text);
    display: inline-flex;
    font-size: var(--rereview-feature-link-size);
    font-weight: 800;
    gap: var(--rereview-feature-link-gap);
    padding-bottom: var(--rereview-feature-link-padding);
    text-decoration: none;
  }

  .rereview-feature a:hover,
  .rereview-feature a:focus-visible {
    color: var(--signal-measured-strong);
  }

  .rereview-feature a:focus-visible {
    outline: var(--rereview-feature-focus-width) solid var(--focus);
    outline-offset: var(--rereview-feature-focus-offset);
  }

  .rereview-feature__player {
    background: var(--signal-model);
    box-shadow: var(--rereview-feature-shadow);
    justify-self: end;
    width: min(100%, var(--rereview-feature-player-width));
  }

  .rereview-feature video {
    aspect-ratio: 9 / 16;
    display: block;
    height: auto;
    width: 100%;
  }

  @media (max-width: 760px) {
    .rereview-feature__shell {
      grid-template-columns: 1fr;
    }

    .rereview-feature__player {
      justify-self: center;
      width: var(--rereview-feature-player-mobile-width);
    }
  }
</style>
