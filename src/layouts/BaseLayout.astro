---
import "@/styles/starwind.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TrackingHead from "../components/TrackingHead.astro";
import {
  absoluteUrl,
  authorName,
  personNode,
  routePath,
  serializeJsonLd,
  siteName,
  siteRoot,
  toJsonLdGraph,
  type JsonLdNode,
  webPageNode,
  websiteNode,
} from "../lib/seo";

interface Props {
  title: string;
  description: string;
  current?: string;
  canonicalPath?: string;
  image?: string;
  noindex?: boolean;
  schema?: JsonLdNode | JsonLdNode[];
  type?: "website" | "article" | "profile";
  pageClass?: string;
}

const {
  title,
  description,
  current = "",
  canonicalPath,
  image,
  noindex = false,
  schema,
  type = "website",
  pageClass = "",
} = Astro.props;
const pageTitle = `${title} | Ying-Fan Lin`;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const pagePath = canonicalPath ?? routePath(Astro.url.pathname);
const canonicalUrl = absoluteUrl(pagePath, Astro.site);
const rootUrl = siteRoot(Astro.site);
const imageUrl = image ? absoluteUrl(image, Astro.site) : undefined;
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    personNode(rootUrl),
    websiteNode(rootUrl),
    webPageNode(rootUrl, canonicalUrl, pageTitle, description),
    ...toJsonLdGraph(schema),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content={authorName} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large"} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <TrackingHead />
    <ClientRouter fallback="swap" />
    <script type="application/ld+json" set:html={serializeJsonLd(jsonLd)} />
    <title>{pageTitle}</title>
  </head>
  <body class={pageClass}>
    <SiteHeader current={current} />
    <main data-pagefind-body>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
