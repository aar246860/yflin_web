---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  networkInvitation,
  researchNetwork,
} from "../../data/researchNetwork";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;
const externalNodes = researchNetwork.filter(
  (node) => node.confirmation === "mutually confirmed",
);
---

<BaseLayout
  title="Research Network"
  description="An opt-in registry of mutually confirmed research connections around groundwater hydraulics, model interpretation, and subsurface energy."
  canonicalPath="/network/"
  current="network"
>
  <section class="shell section group-page-hero">
    <span class="eyebrow">Research network</span>
    <h1>A public network built through explicit, mutual confirmation.</h1>
    <p class="lede">
      This registry identifies research groups that have agreed to describe a
      shared topic in public. A listing records a connection between independent
      sites; it does not imply employment, supervision, endorsement, or ownership
      of another group's work.
    </p>
  </section>

  <section class="shell section" aria-labelledby="network-registry-title">
    <div class="section-head section-head--editorial">
      <div>
        <span class="eyebrow">Confirmed registry</span>
        <h2 id="network-registry-title">Each node states its scope and ownership boundary.</h2>
      </div>
      <p>{researchNetwork.length} site-owned node</p>
    </div>

    <div class="network-list">
      {researchNetwork.map((node) => (
        <article class="network-row">
          <div class="network-row__identity">
            <span class="network-row__status">{node.confirmation}</span>
            <h3>{node.groupName}</h3>
            <p>{node.institution}</p>
          </div>
          <div class="network-row__scope">
            <span class="network-label">Confirmed topics</span>
            <ul>
              {node.sharedTopics.map((topic) => <li>{topic}</li>)}
            </ul>
          </div>
          <div class="network-row__boundary">
            <span class="network-label">Ownership</span>
            <p>{node.ownershipNote}</p>
            <a
              href={node.site.external ? node.site.href : withBase(node.site.href)}
              target={node.site.external ? "_blank" : undefined}
              rel={node.site.external ? "noreferrer" : undefined}
            >
              {node.site.label}<span aria-hidden="true"> &rarr;</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="network-invitation" aria-labelledby="network-invitation-title">
    <div class="shell network-invitation__inner">
      <div>
        <span class="eyebrow">Open by agreement</span>
        <h2 id="network-invitation-title">{networkInvitation.title}</h2>
      </div>
      <div>
        <p>{networkInvitation.body}</p>
        <a class="network-contact" href={networkInvitation.contactHref}>
          {networkInvitation.contactLabel}<span aria-hidden="true"> &rarr;</span>
        </a>
        {externalNodes.length === 0 && (
          <p class="network-empty" role="status">
            No external research groups are listed yet.
          </p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .network-list {
    border-top: 1px solid var(--group-border);
  }

  .network-row {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr) minmax(0, 1.2fr);
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--group-border);
  }

  .network-row h3,
  .network-row p,
  .network-row ul {
    margin: 0;
  }

  .network-row h3 {
    margin-top: 12px;
    color: var(--group-text);
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .network-row p,
  .network-row li,
  .network-invitation p {
    color: var(--group-muted);
    line-height: 1.7;
  }

  .network-row__identity p {
    margin-top: 8px;
  }

  .network-row__status,
  .network-label {
    color: var(--group-red-dark);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .network-row__scope ul {
    padding: 12px 0 0 1.1rem;
  }

  .network-row__scope li + li {
    margin-top: 8px;
  }

  .network-row__boundary p {
    margin-top: 12px;
  }

  .network-row a,
  .network-contact {
    display: inline-block;
    margin-top: 16px;
    color: var(--group-red-dark);
    font-weight: 700;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .network-invitation {
    background: var(--group-gray);
  }

  .network-invitation__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 48px;
    padding-top: 64px;
    padding-bottom: 64px;
  }

  .network-invitation h2 {
    max-width: 18ch;
    margin: 12px 0 0;
    color: var(--group-text);
    font-family: Merriweather, Georgia, serif;
    font-size: 2.45rem;
    line-height: 1.08;
  }

  .network-invitation__inner > div:last-child > p:first-child {
    max-width: 70ch;
    margin-top: 0;
  }

  .network-empty {
    margin: 32px 0 0;
    padding-top: 16px;
    border-top: 1px solid var(--group-border);
    font-size: 0.875rem;
    font-weight: 500;
  }

  @media (max-width: 820px) {
    .network-row,
    .network-invitation__inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .network-invitation h2 {
      font-size: 2rem;
    }
  }
</style>
