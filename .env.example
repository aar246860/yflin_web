# Optional site verification and analytics hooks.
# Copy values into local `.env` or GitHub Actions repository secrets.

# Google Search Console meta verification token.
# The deployed site also keeps `public/google0b5a64cc3a32bc0f.html` for HTML-file verification.
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools meta verification token.
PUBLIC_BING_SITE_VERIFICATION=

# Google Analytics 4 measurement ID, for example `G-XXXXXXXXXX`.
PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID.
PUBLIC_CLARITY_PROJECT_ID=

# Cloudflare Web Analytics token.
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Data enrichment for the weekly visibility report. Do not expose these as PUBLIC_*.
GSC_ACCESS_TOKEN=
OPENALEX_API_KEY=
OPENALEX_MAILTO=
CROSSREF_MAILTO=
INDEXNOW_KEY=
